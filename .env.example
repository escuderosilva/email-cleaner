# Copia este archivo como ".env" y pega tus credenciales.
# El .env NO se sube a Drive ni a git (contiene credenciales).

# HubSpot (opcional): Service Key para marcar el estado en el CRM.
HUBSPOT_TOKEN=pega-aqui-tu-service-key

# Registro de uso en Google Sheet (opcional). Si no lo configuras, el log queda
# solo en stdout y en el CSV local.
# USAGE_SHEET_ID = ID de la hoja (lo que va entre /d/ y /edit en la URL).
# GCP_SERVICE_ACCOUNT_JSON = el JSON del service account, en UNA sola línea.
USAGE_SHEET_ID=
GCP_SERVICE_ACCOUNT_JSON=
